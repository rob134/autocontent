# Database
DATABASE_URL=sqlite:///./autocontent.db

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256

# OAuth - YouTube (add your credentials)
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback

# Storage
STORAGE_PATH=./storage
TEMP_PATH=./temp

# Processing
FFMPEG_PATH=ffmpeg
WHISPER_MODEL=base
TTS_ENGINE=coqui

# Features
ENABLE_SCHEDULER=false
ENABLE_ADS_MODE=false
ENABLE_AVATAR_MODE=false
ENABLE_CREATOR_PROFILES=false

# Logging
LOG_LEVEL=INFO
